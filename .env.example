# Copy to .env.local and fill in real values.
# Never commit .env.local.

# Neon Postgres (full connection string, sslmode=require)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# NextAuth (Auth.js) — generate SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Supabase Storage (Phase 3)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend email (Phase 3)
RESEND_API_KEY=
ADMIN_EMAIL=nicholas@kojafamily.com
